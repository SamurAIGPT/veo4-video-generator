# Environment
DATABASE_URL="postgresql://user:password@host:port/dbname"
DIRECT_URL="postgresql://user:password@host:port/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Google Auth (for login)
GOOGLE_CLIENT_ID="your_google_id_here"
GOOGLE_CLIENT_SECRET="your_google_secret_here"

# Veo 3.1 API (for video generation)
VEO31_API_KEY="your_veo31_api_key_here"
WEBHOOK_URL="your_webhook_url"

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Dynamic UI Theme Configuration
# Hosted Admins: Choose between: indigo, emerald, rose, amber, violet
NEXT_PUBLIC_THEME=rose
